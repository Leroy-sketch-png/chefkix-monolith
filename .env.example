# ═══════════════════════════════════════════════════════════════
# ChefKix Monolith — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your local values.
# Spring Boot loads env vars that override application.yml defaults.
#
# For local dev with dev.bat, these defaults match Docker infra:
#   MongoDB: chefkix / chefkix-dev-password
#   Redis:   chefkix-dev-password
#   Keycloak: admin / admin
# ═══════════════════════════════════════════════════════════════

# ── MongoDB ──
# Default in application.yml matches Docker dev credentials.
# Override only if you changed infra passwords:
# MONGODB_URI=mongodb://chefkix:chefkix-dev-password@localhost:27017/chefkix?authSource=admin

# ── Redis ──
# Default in application.yml matches Docker dev password.
# Override only if you changed infra passwords:
# SPRING_DATA_REDIS_PASSWORD=chefkix-dev-password

# ── Keycloak / IDP ──
IDP_URL=http://localhost:8180
IDP_CLIENT_ID=chefkix-be
IDP_CLIENT_SECRET=your-keycloak-client-secret-here
KEYCLOAK_URL=http://localhost:8180

# ── Brevo Email ──
BREVO_API_KEY=xkeysib-your-brevo-api-key-here

# ── Cloudinary (Image/Video Uploads) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── OTP ──
APP_OTP_SECRET=chefkix-dev-otp-secret-change-in-prod

# ── Swagger (enabled for local dev) ──
SPRINGDOC_ENABLED=true

# ── Cookie ──
APP_COOKIE_DOMAIN=localhost
APP_COOKIE_SECURE=false

# ── Push Notifications (optional) ──
PUSH_ENABLED=false
# FIREBASE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
