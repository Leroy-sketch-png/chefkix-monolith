# ═══════════════════════════════════════════════════════════════
# ChefKix Monolith — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your local values.
# Spring Boot now fails closed when required credential env vars are missing.
# Copy real local values from your ignored chefkix-infrastructure/.env.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB ──
# Required. Use the Mongo password from ignored chefkix-infrastructure/.env.
MONGODB_URI=mongodb://chefkix:CHANGE_ME@localhost:27017/chefkix?authSource=admin

# ── Redis ──
# Required. Use the Redis password from ignored chefkix-infrastructure/.env.
SPRING_DATA_REDIS_PASSWORD=CHANGE_ME

# ── Keycloak / IDP ──
IDP_URL=http://localhost:8180
IDP_CLIENT_ID=chefkix-be
IDP_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_URL=http://localhost:8180

# ── Brevo Email ──
BREVO_API_KEY=CHANGE_ME

# ── Cloudinary (Image/Video Uploads) ──
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── OTP ──
APP_OTP_SECRET=CHANGE_ME

# ── Swagger (enabled for local dev) ──
SPRINGDOC_ENABLED=true

# ── Cookie ──
APP_COOKIE_DOMAIN=localhost
APP_COOKIE_SECURE=false

# ── Push Notifications (optional) ──
PUSH_ENABLED=false
# FIREBASE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
